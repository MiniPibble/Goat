-- Helpers
local function lsLerpColor(a, b, t)
	return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end
local function lsRainbow(t)
	local c = LS_CONFIG.BarColors
	local n = #c
	local s = t * n
	local i = math.floor(s) % n + 1
	local j = i % n + 1
	return lsLerpColor(c[i], c[j], s - math.floor(s))
end
local function lsStatus(pct)
	local msg = LS_CONFIG.StatusMessages[0]
	for th, lb in pairs(LS_CONFIG.StatusMessages) do
		if pct >= th then msg = lb end
	end
	return msg
end
local function lsFadeOut(obj, dur)
	if obj:IsA("TextLabel") or obj:IsA("TextButton") then
		TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), {TextTransparency=1}):Play()
	elseif obj:IsA("ImageLabel") then
		TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), {ImageTransparency=1}):Play()
	elseif obj:IsA("Frame") then
		TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), {BackgroundTransparency=1}):Play()
	end
end
local function lsFadeIn(obj, dur)
	if obj:IsA("TextLabel") or obj:IsA("TextButton") then
		TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), {TextTransparency=0}):Play()
	elseif obj:IsA("ImageLabel") then
		TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), {ImageTransparency=0}):Play()
	elseif obj:IsA("Frame") then
		TweenService:Create(obj, TweenInfo.new(dur, Enum.EasingStyle.Quad), {BackgroundTransparency=0}):Play()
	end
end

