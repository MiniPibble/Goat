-- Main loading loop
local lsStartTime = tick()
local lsRainbowT  = 0
local lsDotPulse  = 0
local lsFinished  = false

local lsConn
lsConn = RunService.Heartbeat:Connect(function(dt)
	if lsFinished then return end
	local elapsed   = tick() - lsStartTime
	local progress  = math.min(elapsed / LS_CONFIG.LoadTime, 1)
	local pct       = math.floor(progress * 100)
	local remaining = math.max(0, math.ceil(LS_CONFIG.LoadTime - elapsed))

	TweenService:Create(lsBarFill, TweenInfo.new(0.25, Enum.EasingStyle.Linear), {
		Size = UDim2.new(progress,0,1,0)
	}):Play()

	lsPctLabel.Text    = pct.."%"
	lsStatusLabel.Text = lsStatus(pct)
	lsTimeLabel.Text   = remaining > 0 and (remaining.."s remaining") or "Done!"

	lsRainbowT = (lsRainbowT + dt * 0.5) % 1
	lsCardStroke.Color              = lsRainbow(lsRainbowT)
	lsRingStroke.Color              = lsRainbow((lsRainbowT + 0.33) % 1)
	lsBarFill.BackgroundColor3      = lsRainbow((lsRainbowT + 0.66) % 1)
	lsRestoreStroke.Color           = lsRainbow(lsRainbowT)

	lsDotPulse = (lsDotPulse + dt * 1.8) % 1
	for i, dot in ipairs(lsDots) do
		local phase = (lsDotPulse + (i-1)*0.18) % 1
		local b = 0.15 + math.abs(math.sin(phase * math.pi)) * 0.7
		dot.BackgroundColor3 = Color3.new(b, b, b+0.05)
	end

	if progress >= 1 then
		lsFinished = true
		lsConn:Disconnect()
		task.wait(0.6)

		lsWarnBackdrop.Visible = false
		lsRestoreBtn.Visible   = false

		TweenService:Create(lsCard, TweenInfo.new(1.2, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size     = UDim2.new(0,240,0,240),
			Position = UDim2.new(0.5,0,0.47,0),
		}):Play()
		TweenService:Create(lsCard, TweenInfo.new(1, Enum.EasingStyle.Quad), {BackgroundTransparency=1}):Play()
		TweenService:Create(lsCardStroke, TweenInfo.new(0.8, Enum.EasingStyle.Quad), {Transparency=1}):Play()
		for _, child in ipairs(lsCard:GetDescendants()) do lsFadeOut(child, 0.8) end

		task.wait(1.4)
		lsGui:Destroy()

		-- ========================================================
		-- LAUNCH EMERALD EDITION AFTER LOADING SCREEN FINISHES
		-- ========================================================
		task.spawn(function() _G.MingScriptsEmeraldReady = true end)
	end
end)

